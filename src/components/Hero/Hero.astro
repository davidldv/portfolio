---
import HeroScene from './HeroScene';
---

<section id="hero" class="hero relative flex min-h-svh w-full items-center justify-center overflow-hidden px-[clamp(1rem,2.6vw,2rem)] pb-0 pt-16 before:pointer-events-none before:absolute before:inset-0 before:z-1 before:content-[''] before:[background:linear-gradient(180deg,rgba(3_7_18/0.28)_0%,rgba(3_7_18/0.12)_52%,rgba(3_7_18/0)_100%),radial-gradient(66%_44%_at_50%_12%,rgba(22_40_108/0.2),transparent_72%)]">
  <div class="hero-orb fixed inset-0 z-0 pointer-events-none lg:hidden" aria-hidden="true"></div>
  <HeroScene client:only="react" />
  <div class="hero-backdrop pointer-events-none absolute inset-0 z-2 [background:var(--hero-backdrop)]" aria-hidden="true"></div>

  <div class="hero-content relative z-3 flex max-w-170 flex-col items-center text-center">
    <div class="role-badge-wrap relative mb-6 inline-flex rounded-full p-[1.5px] opacity-0 animate-[fade-up_0.6s_ease_forwards_0.2s,badge-spin_4s_linear_2.7s_infinite]">
      <div class="badge-hover-glow pointer-events-none absolute -inset-3 rounded-full opacity-0 blur-[3px] transition-opacity duration-300 [background:radial-gradient(80px_50px_at_var(--mx,50%)_var(--my,50%),rgba(0_212_255/0.28),transparent_70%)]" aria-hidden="true"></div>
      <div class="badge-border-counter pointer-events-none absolute inset-0 z-0 rounded-full animate-[badge-spin-rev_6.5s_linear_2.7s_infinite]" aria-hidden="true"></div>
      <div class="role-badge relative z-1 inline-flex cursor-default items-center gap-2 overflow-hidden rounded-full border px-4 py-1.5 pl-2.5 [background:var(--badge-bg)] [border:var(--badge-border)] [box-shadow:var(--badge-shadow)] [backdrop-filter:blur(20px)_saturate(150%)] transition-colors duration-200">
        <span class="role-badge-dot relative z-1 h-1.75 w-1.75 shrink-0 rounded-full [background:var(--badge-dot)] animate-[dot-pulse_2.5s_ease-in-out_infinite]" aria-hidden="true"></span>
        <span class="role-badge-text relative z-1 font-mono text-[0.73rem] uppercase tracking-[0.12em] text-(--badge-text)">Software Engineer · Application Security & AI Systems</span>
      </div>
    </div>

    <h1 class="hero-title mb-6 text-[clamp(3.5rem,9vw,7rem)] font-bold leading-[0.93] tracking-[-0.04em] text-fg opacity-0 animate-[fade-up_0.6s_ease_forwards_0.35s] [text-shadow:0_4px_32px_rgba(94_106_210/0.28)]">
      David<br />
      Builds &amp; Breaks
    </h1>

    <p class="hero-subtitle mb-10 text-[clamp(1rem,2vw,1.15rem)] leading-[1.75] text-fg-muted opacity-0 animate-[fade-up_0.6s_ease_forwards_0.5s] [text-shadow:0_1px_8px_rgba(0_0_0/0.4)]">
      Full-Stack Engineer focused on Application Security.<br class="hidden sm:inline" />
      Shipping web systems with security as a design input, not an afterthought.
    </p>

    <div class="hero-actions flex flex-wrap items-center justify-center gap-4 opacity-0 animate-[fade-up_0.6s_ease_forwards_0.65s]">
      <a href="#about" class="hero-cta inline-flex items-center gap-2 rounded-(--radius) bg-accent px-8 py-3.5 text-[0.95rem] font-semibold text-white no-underline shadow-[0_0_40px_var(--accent-glow)] transition-all duration-200 hover:-translate-y-0.5 hover:opacity-[0.88] focus-visible:outline-2 focus-visible:outline-offset-3 focus-visible:outline-accent">
        Explore my journey
        <svg
          width="16"
          height="16"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2.5"
          aria-hidden="true"
        >
          <path d="M12 5v14M5 12l7 7 7-7" />
        </svg>
      </a>

      <a
        href="https://github.com/davidldv"
        target="_blank"
        rel="noopener noreferrer"
        class="hero-secondary-link inline-flex items-center gap-1.5 rounded-(--radius) border border-border bg-surface px-6 py-3.5 text-[0.95rem] font-medium text-fg-muted no-underline transition-colors duration-150 hover:border-accent hover:bg-accent-glow hover:text-fg focus-visible:outline-2 focus-visible:outline-offset-3 focus-visible:outline-accent"
        aria-label="GitHub profile"
      >
        <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path
            d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0 1 12 6.844a9.59 9.59 0 0 1 2.504.337c1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.02 10.02 0 0 0 22 12.017C22 6.484 17.522 2 12 2z"
          />
        </svg>
        GitHub
      </a>
    </div>

    <div class="scroll-indicator mt-16 flex justify-center opacity-0 animate-[fade-up_0.6s_ease_forwards_1s]" aria-hidden="true">
      <span class="scroll-line block h-12 w-px [background:linear-gradient(to_bottom,var(--accent),transparent)] animate-[scroll-pulse_2s_ease-in-out_infinite]"></span>
    </div>
  </div>
</section>

<script>
  const bindBadgeGlow = () => {
    const badgeWrap = document.querySelector<HTMLElement>('.role-badge-wrap');
    if (!badgeWrap) return;

    const onMouseMove = (e: MouseEvent) => {
      const r = badgeWrap.getBoundingClientRect();
      badgeWrap.style.setProperty('--mx', `${e.clientX - r.left}px`);
      badgeWrap.style.setProperty('--my', `${e.clientY - r.top}px`);
    };

    if (badgeWrap.dataset.glowBound === 'true') return;
    badgeWrap.dataset.glowBound = 'true';
    window.addEventListener('mousemove', onMouseMove, { passive: true });
  };

  document.addEventListener('astro:page-load', bindBadgeGlow);
  bindBadgeGlow();
</script>
