---
import HeroScene from './HeroScene';
---

<section id="hero" class="hero">
  <div class="hero-orb" aria-hidden="true"></div>
  <HeroScene client:only="react" />
  <div class="hero-backdrop" aria-hidden="true"></div>

  <div class="hero-content">
    <div class="role-badge-wrap">
      <div class="badge-hover-glow" aria-hidden="true"></div>
      <div class="badge-border-counter" aria-hidden="true"></div>
      <div class="role-badge" aria-label="Current role">
        <span class="role-badge-dot" aria-hidden="true"></span>
        <span class="role-badge-text">Full Stack Engineer · AI Systems</span>
      </div>
    </div>

    <h1 class="hero-title">
      David<br />
      AI Builder
    </h1>

    <p class="hero-subtitle">
      Building AI-native systems where the model<br class="subtitle-br" />
      is the orchestration layer, not just a feature.
    </p>

    <div class="hero-actions">
      <a href="#about" class="hero-cta">
        Explore my journey
        <svg
          width="16"
          height="16"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2.5"
          aria-hidden="true"
        >
          <path d="M12 5v14M5 12l7 7 7-7" />
        </svg>
      </a>

      <a
        href="https://github.com/davidldv"
        target="_blank"
        rel="noopener noreferrer"
        class="hero-secondary-link"
        aria-label="GitHub profile"
      >
        <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path
            d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0 1 12 6.844a9.59 9.59 0 0 1 2.504.337c1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.02 10.02 0 0 0 22 12.017C22 6.484 17.522 2 12 2z"
          />
        </svg>
        GitHub
      </a>
    </div>

    <div class="scroll-indicator" aria-hidden="true">
      <span class="scroll-line"></span>
    </div>
  </div>
</section>

<style>
  .hero {
    position: relative;
    width: 100%;
    min-height: 100svh;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 64px clamp(1rem, 2.6vw, 2rem) 0;
    overflow: hidden;
  }

  .hero::before {
    content: '';
    position: absolute;
    inset: 0;
    pointer-events: none;
    z-index: 1;
    background:
      linear-gradient(180deg, rgba(3 7 18 / 0.28) 0%, rgba(3 7 18 / 0.12) 52%, rgba(3 7 18 / 0) 100%),
      radial-gradient(66% 44% at 50% 12%, rgba(22 40 108 / 0.2), transparent 72%);
  }

  .hero-orb {
    position: fixed;
    inset: 0;
    z-index: 0;
    background:
      radial-gradient(ellipse 80% 60% at 50% 30%, var(--accent-glow) 0%, transparent 65%),
      radial-gradient(ellipse 50% 40% at 80% 80%, rgba(0 212 255 / 0.08) 0%, transparent 60%);
    pointer-events: none;
    animation: orb-breathe 6s ease-in-out infinite;
  }

  [data-theme='light'] .hero-orb {
    background:
      radial-gradient(ellipse 80% 60% at 50% 30%, rgba(79 70 229 / 0.1) 0%, transparent 65%),
      radial-gradient(ellipse 50% 40% at 80% 80%, rgba(8 145 178 / 0.06) 0%, transparent 60%);
  }

  @media (min-width: 1024px) {
    .hero-orb {
      display: none;
    }
  }

  @keyframes orb-breathe {
    0%,
    100% {
      opacity: 0.6;
      transform: scale(1);
    }
    50% {
      opacity: 1;
      transform: scale(1.08);
    }
  }

  .hero-backdrop {
    position: absolute;
    inset: 0;
    background: var(--hero-backdrop);
    pointer-events: none;
    z-index: 2;
  }

  .hero-content {
    position: relative;
    z-index: 3;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    max-width: 680px;
    gap: 0;
  }

  @property --badge-angle {
    syntax: '<angle>';
    initial-value: 0deg;
    inherits: false;
  }

  @property --badge-angle-rev {
    syntax: '<angle>';
    initial-value: 360deg;
    inherits: false;
  }

  .role-badge-wrap {
    position: relative;
    display: inline-flex;
    border-radius: 999px;
    padding: 1.5px;
    margin-bottom: 1.5rem;
    opacity: 0;
    animation: fade-up 0.6s ease forwards 0.2s, badge-spin 4s linear 2.7s infinite;
  }

  @keyframes badge-spin {
    from {
      --badge-angle: 0deg;
    }
    to {
      --badge-angle: 360deg;
    }
  }

  @keyframes badge-spin-rev {
    from {
      --badge-angle-rev: 360deg;
    }
    to {
      --badge-angle-rev: 0deg;
    }
  }

  .role-badge-wrap::before {
    content: '';
    position: absolute;
    inset: 0;
    border-radius: 999px;
    background: conic-gradient(
      from var(--badge-angle),
      rgba(94 106 210 / 0.15) 0deg,
      rgba(0 212 255 / 0.95) 18deg,
      rgba(255 255 255 / 0.85) 27deg,
      rgba(94 106 210 / 0.15) 44deg,
      rgba(94 106 210 / 0.15) 360deg
    );
  }

  .badge-border-counter {
    pointer-events: none;
    position: absolute;
    inset: 0;
    border-radius: 999px;
    background: conic-gradient(
      from var(--badge-angle-rev),
      rgba(94 106 210 / 0.08) 0deg,
      rgba(148 130 255 / 0.7) 16deg,
      rgba(200 210 255 / 0.5) 24deg,
      rgba(94 106 210 / 0.08) 42deg,
      rgba(94 106 210 / 0.08) 360deg
    );
    animation: badge-spin-rev 6.5s linear 2.7s infinite;
    z-index: 0;
  }

  .badge-hover-glow {
    pointer-events: none;
    position: absolute;
    inset: -12px;
    border-radius: 999px;
    background: radial-gradient(
      80px 50px at var(--mx, 50%) var(--my, 50%),
      rgba(0 212 255 / 0.28),
      transparent 70%
    );
    z-index: 0;
    opacity: 0;
    transition: opacity 300ms ease;
    filter: blur(3px);
  }

  .role-badge-wrap:hover .badge-hover-glow {
    opacity: 1;
  }

  .role-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.4rem 1rem 0.4rem 0.65rem;
    border-radius: 999px;
    background: var(--badge-bg);
    border: var(--badge-border);
    box-shadow: var(--badge-shadow);
    backdrop-filter: blur(20px) saturate(150%);
    -webkit-backdrop-filter: blur(20px) saturate(150%);
    position: relative;
    z-index: 1;
    overflow: hidden;
    cursor: default;
    transition: background 200ms ease, border-color 200ms ease;
  }

  .role-badge-wrap:hover .role-badge {
    background: var(--badge-bg-hover);
  }

  .role-badge::after {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(
      105deg,
      transparent 30%,
      rgba(255 255 255 / 0.18) 50%,
      transparent 70%
    );
    transform: translateX(-100%);
    animation: badge-shimmer 4s ease-in-out infinite 2.5s;
    pointer-events: none;
  }

  @keyframes badge-shimmer {
    0% {
      transform: translateX(-100%);
    }
    30%,
    100% {
      transform: translateX(220%);
    }
  }

  .role-badge-dot {
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background: var(--badge-dot);
    flex-shrink: 0;
    position: relative;
    z-index: 1;
    animation: dot-pulse 2.5s ease-in-out infinite;
  }

  @keyframes dot-pulse {
    0%,
    100% {
      box-shadow:
        0 0 0 2px rgba(0 212 255 / 0.2),
        0 0 8px rgba(0 212 255 / 0.6);
    }
    50% {
      box-shadow:
        0 0 0 4px rgba(0 212 255 / 0.1),
        0 0 14px rgba(0 212 255 / 0.9),
        0 0 26px rgba(0 212 255 / 0.3);
    }
  }

  .role-badge-text {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.73rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--badge-text);
    position: relative;
    z-index: 1;
  }

  [data-theme='light'] .role-badge-wrap::before {
    background: conic-gradient(
      from var(--badge-angle),
      rgba(79 70 229 / 0.12) 0deg,
      rgba(8 145 178 / 0.9) 20deg,
      rgba(255 255 255 / 0.8) 30deg,
      rgba(79 70 229 / 0.12) 50deg,
      rgba(79 70 229 / 0.12) 360deg
    );
  }

  [data-theme='light'] .badge-border-counter {
    background: conic-gradient(
      from var(--badge-angle-rev),
      rgba(79 70 229 / 0.05) 0deg,
      rgba(79 70 229 / 0.5) 16deg,
      rgba(165 180 252 / 0.4) 24deg,
      rgba(79 70 229 / 0.05) 42deg,
      rgba(79 70 229 / 0.05) 360deg
    );
  }

  [data-theme='light'] .badge-hover-glow {
    background: radial-gradient(
      80px 50px at var(--mx, 50%) var(--my, 50%),
      rgba(8 145 178 / 0.22),
      transparent 70%
    );
  }

  .hero-title {
    font-size: clamp(3.5rem, 9vw, 7rem);
    font-weight: 700;
    letter-spacing: -0.04em;
    line-height: 0.93;
    margin-bottom: 1.5rem;
    opacity: 0;
    animation: fade-up 0.6s ease forwards 0.35s;
    background: var(--hero-title-gradient);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    filter: var(--hero-title-filter);
  }

  .hero-subtitle {
    font-size: clamp(1rem, 2vw, 1.15rem);
    color: var(--foreground-muted);
    line-height: 1.75;
    margin-bottom: 2.5rem;
    opacity: 0;
    animation: fade-up 0.6s ease forwards 0.5s;
    text-shadow: 0 1px 8px rgba(0 0 0 / 0.4);
  }

  .subtitle-br {
    display: none;
  }

  @media (min-width: 640px) {
    .subtitle-br {
      display: inline;
    }
  }

  .hero-actions {
    display: flex;
    align-items: center;
    gap: 1rem;
    flex-wrap: wrap;
    justify-content: center;
    opacity: 0;
    animation: fade-up 0.6s ease forwards 0.65s;
  }

  .hero-cta {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.875rem 2rem;
    border-radius: var(--radius);
    background: var(--accent);
    color: #fff;
    font-weight: 600;
    font-size: 0.95rem;
    text-decoration: none;
    box-shadow: 0 0 40px var(--accent-glow);
    transition: opacity 200ms ease, transform 200ms ease, box-shadow 200ms ease;
  }

  .hero-cta:hover {
    opacity: 0.88;
    transform: translateY(-1px);
  }

  .hero-cta:focus-visible {
    outline: 2px solid var(--accent);
    outline-offset: 3px;
  }

  .hero-secondary-link {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.875rem 1.5rem;
    border-radius: var(--radius);
    border: 1px solid var(--border);
    background: var(--bg-surface);
    color: var(--foreground-muted);
    font-weight: 500;
    font-size: 0.95rem;
    text-decoration: none;
    transition: color 150ms ease, border-color 150ms ease, background 150ms ease;
  }

  .hero-secondary-link:hover {
    color: var(--foreground);
    border-color: var(--accent);
    background: var(--accent-glow);
  }

  .hero-secondary-link:focus-visible {
    outline: 2px solid var(--accent);
    outline-offset: 3px;
  }

  .scroll-indicator {
    margin-top: 4rem;
    display: flex;
    justify-content: center;
    opacity: 0;
    animation: fade-up 0.6s ease forwards 1s;
  }

  .scroll-line {
    display: block;
    width: 1px;
    height: 48px;
    background: linear-gradient(to bottom, var(--accent), transparent);
    animation: scroll-pulse 2s ease-in-out infinite;
  }

  @keyframes scroll-pulse {
    0%,
    100% {
      opacity: 0.4;
      transform: scaleY(1);
    }
    50% {
      opacity: 1;
      transform: scaleY(1.1);
    }
  }

  @keyframes fade-up {
    from {
      opacity: 0;
      transform: translateY(1.5rem);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .role-badge-wrap,
    .hero-title,
    .hero-subtitle,
    .hero-actions,
    .scroll-indicator {
      animation: none;
      opacity: 1;
      transform: none;
    }

    .role-badge-wrap::before,
    .badge-border-counter,
    .role-badge::after,
    .role-badge-dot,
    .hero-orb,
    .scroll-line {
      animation: none;
    }
  }
</style>

<script>
  const bindBadgeGlow = () => {
    const badgeWrap = document.querySelector<HTMLElement>('.role-badge-wrap');
    if (!badgeWrap) return;

    const onMouseMove = (e: MouseEvent) => {
      const r = badgeWrap.getBoundingClientRect();
      badgeWrap.style.setProperty('--mx', `${e.clientX - r.left}px`);
      badgeWrap.style.setProperty('--my', `${e.clientY - r.top}px`);
    };

    if (badgeWrap.dataset.glowBound === 'true') return;
    badgeWrap.dataset.glowBound = 'true';
    window.addEventListener('mousemove', onMouseMove, { passive: true });
  };

  document.addEventListener('astro:page-load', bindBadgeGlow);
  bindBadgeGlow();
</script>
