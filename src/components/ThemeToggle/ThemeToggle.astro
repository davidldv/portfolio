---
// ThemeToggle: triggers clip-path propagation transition from button position
---

<button
  id="theme-toggle"
  type="button"
  data-theme-toggle
  aria-label="Toggle dark/light mode"
  title="Toggle theme"
  class="theme-toggle group flex h-10 w-10 items-center justify-center rounded-full border border-border bg-surface text-fg-muted transition-colors duration-150 hover:border-accent hover:bg-accent-glow hover:text-fg focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-accent"
>
  <svg
    class="icon-sun group-data-[theme=light]:hidden"
    xmlns="http://www.w3.org/2000/svg"
    width="18"
    height="18"
    viewBox="0 0 24 24"
    fill="none"
    stroke="currentColor"
    stroke-width="2"
    stroke-linecap="round"
    stroke-linejoin="round"
    aria-hidden="true"
  >
    <circle cx="12" cy="12" r="4"></circle>
    <path d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M6.34 17.66l-1.41 1.41M19.07 4.93l-1.41 1.41"></path>
  </svg>
  <svg
    class="icon-moon hidden group-data-[theme=light]:block"
    xmlns="http://www.w3.org/2000/svg"
    width="18"
    height="18"
    viewBox="0 0 24 24"
    fill="none"
    stroke="currentColor"
    stroke-width="2"
    stroke-linecap="round"
    stroke-linejoin="round"
    aria-hidden="true"
  >
    <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"></path>
  </svg>
</button>

