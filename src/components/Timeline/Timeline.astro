---
import { TimelineInteractive } from './TimelineInteractive';
---

<section id="timeline" class="relative z-2 pt-24">
  <div class="reveal mx-auto mb-4 max-w-7xl px-6 pl-10">
    <p class="mb-2 font-mono text-[0.78rem] uppercase tracking-[0.14em] text-accent-secondary">Career</p>
    <h2 class="text-[clamp(2rem,5vw,3.5rem)] font-bold tracking-[-0.04em] text-fg">Experience</h2>
  </div>

  <TimelineInteractive client:visible />
</section>
