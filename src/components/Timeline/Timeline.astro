---
import type { TimelineItem } from '../../lib/portfolio-data';

interface Props {
  items: TimelineItem[];
}

const { items } = Astro.props as Props;
---

<section class="timeline-section" id="timeline" aria-labelledby="timeline-heading">
  <h2 id="timeline-heading">Experience</h2>

  <ol class="experience-list" data-animated-timeline>
    {
      items.map((item, index) => (
        <li class="experience-item" data-timeline-item style={`--item-index: ${index};`}>
          <div class="experience-rail" aria-hidden="true">
            <span class="experience-node"></span>
            <span class="experience-year">{item.year}</span>
          </div>
          <article class="experience-card">
            <header class="experience-header">
              <h3>{item.company}</h3>
              {item.current && <span class="experience-status">Current</span>}
            </header>
            <p class="experience-role">
              <strong>{item.role}</strong>
              <span>{item.period}</span>
            </p>
            <p class="experience-summary">{item.summary}</p>
            <div class="experience-tags">
              {item.tags.map((tag) => (
                <span>{tag}</span>
              ))}
            </div>
          </article>
        </li>
      ))
    }
  </ol>
</section>

<script is:inline>
  (() => {
    const initTimelines = () => {
      const timelines = document.querySelectorAll('[data-animated-timeline]');

      for (const timeline of timelines) {
        if (timeline instanceof HTMLElement && timeline.dataset.timelineReady === 'true') {
          continue;
        }

        if (!(timeline instanceof HTMLElement)) {
          continue;
        }

        timeline.dataset.timelineReady = 'true';

        const items = Array.from(timeline.querySelectorAll('[data-timeline-item]'));
        const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

        if (reduceMotion) {
          timeline.style.setProperty('--timeline-progress', '1');
          for (const item of items) {
            item.classList.add('is-visible', 'is-active');
          }
          continue;
        }

        const observer = new IntersectionObserver(
          (entries) => {
            for (const entry of entries) {
              if (entry.isIntersecting) {
                entry.target.classList.add('is-visible');
                observer.unobserve(entry.target);
              }
            }
          },
          { threshold: 0.22, rootMargin: '0px 0px -12% 0px' },
        );

        for (const item of items) {
          observer.observe(item);
        }

        let ticking = false;

        const updateProgress = () => {
          const bounds = timeline.getBoundingClientRect();
          const viewport = Math.max(window.innerHeight, 1);
          const start = bounds.top + window.scrollY - viewport * 0.68;
          const end = bounds.bottom + window.scrollY - viewport * 0.3;
          const raw = (window.scrollY - start) / Math.max(end - start, 1);
          const progress = Math.min(Math.max(raw, 0), 1);

          timeline.style.setProperty('--timeline-progress', progress.toFixed(3));

          const activeCount = progress * items.length;
          for (let index = 0; index < items.length; index += 1) {
            const item = items[index];
            if (index + 0.55 <= activeCount) {
              item.classList.add('is-active');
            } else {
              item.classList.remove('is-active');
            }
          }

          ticking = false;
        };

        const onScroll = () => {
          if (!ticking) {
            ticking = true;
            window.requestAnimationFrame(updateProgress);
          }
        };

        updateProgress();
        window.addEventListener('scroll', onScroll, { passive: true });
        window.addEventListener('resize', onScroll);
      }
    };

    document.addEventListener('astro:page-load', initTimelines);
    initTimelines();
  })();
</script>
