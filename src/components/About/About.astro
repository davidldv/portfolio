---
import { ui, type Lang } from '../../i18n/ui';

interface Props {
  lang?: Lang;
}

const { lang = 'en' } = Astro.props as Props;
const t = ui[lang].about;
---

<section id="about" class="relative z-2 px-6 py-28">
  <div class="mx-auto max-w-7xl">
    <div class="reveal mb-14">
      <p class="mb-2 font-mono text-[0.78rem] uppercase tracking-[0.14em] text-accent-secondary">{t.eyebrow}</p>
      <h2 class="text-[clamp(2rem,5vw,3.5rem)] font-bold tracking-[-0.04em] text-fg">{t.heading}</h2>
    </div>

    <div class="grid grid-cols-1 items-start gap-12 md:grid-cols-[280px_1fr] md:gap-16 lg:grid-cols-[320px_1fr] lg:gap-20">
      <div class="about-portrait reveal flex justify-center">
        <div class="portrait-frame relative w-full max-w-75 overflow-hidden rounded-2xl bg-[#050506]">
          <img
            src="/david.jpg"
            alt={t.portraitAlt}
            width="400"
            height="500"
            loading="lazy"
            decoding="async"
            class="relative z-1 block h-auto w-full mix-blend-lighten mask-[linear-gradient(to_bottom,black_65%,transparent_100%)]"
          />
          <div class="portrait-glow absolute inset-0 z-0 blur-3xl [background:radial-gradient(ellipse_70%_60%_at_50%_40%,var(--accent-glow),transparent_70%),radial-gradient(ellipse_50%_40%_at_80%_20%,rgba(0_212_255/0.15),transparent_60%)]" aria-hidden="true"></div>
        </div>
      </div>

      <div class="about-right flex flex-col gap-10">
        <div class="about-bio reveal">
          <p class="mb-5 text-[1.05rem] leading-[1.8] text-fg-muted">{t.p1}</p>
          <p class="mb-5 text-[1.05rem] leading-[1.8] text-fg-muted">{t.p2}</p>
          <p class="mb-7 text-[1.05rem] leading-[1.8] text-fg-muted">{t.p3}</p>
          <p class="mb-7 text-[1.05rem] leading-[1.8] text-fg-muted">{t.p4}</p>

          <div class="bio-location inline-flex items-center gap-1.5 rounded-full border border-border bg-surface px-3.5 py-1.5 font-mono text-[0.85rem] text-fg-muted">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M20 10c0 6-8 13-8 13s-8-7-8-13a8 8 0 0 1 16 0Z"/>
              <circle cx="12" cy="10" r="3"/>
            </svg>
            {t.location}
          </div>
        </div>

        <div class="about-stats reveal grid grid-cols-2 gap-4 sm:grid-cols-4">
          {t.stats.map(({ value, label }) => (
            <div class="stat-card flex flex-col gap-1.5 rounded-2xl border border-border bg-surface-elevated px-6 py-5 transition-colors duration-200 hover:border-accent-border">
              <span class="bg-linear-to-br from-accent to-accent-secondary bg-clip-text font-mono text-[1.75rem] font-bold tracking-[-0.04em] text-transparent">{value}</span>
              <span class="text-[0.78rem] font-medium text-fg-muted">{label}</span>
            </div>
          ))}
        </div>
      </div>
    </div>
  </div>
</section>
