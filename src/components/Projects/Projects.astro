---
import { ui, type Lang } from '../../i18n/ui';

interface Props {
  lang?: Lang;
}

const { lang = 'en' } = Astro.props as Props;
const t = ui[lang].projects;

interface Project {
  id: keyof typeof t.items;
  name: string;
  tags: string[];
  href: string | null;
  accent: 'indigo' | 'cyan';
}

const baseProjects: Project[] = [
  {
    id: 'paircode',
    name: 'PairCode',
    tags: ['Next.js', 'PostgreSQL', 'EdDSA', 'Argon2id', 'RBAC', 'WebSockets'],
    href: 'https://paircode-lime.vercel.app/',
    accent: 'indigo',
  },
  {
    id: 'jwt-lab',
    name: 'JWT Security Lab',
    tags: ['TypeScript', 'Node.js', 'Docker', 'JWT', 'OpenSSL', 'Bash'],
    href: 'https://github.com/davidldv/jwtsecuritylab',
    accent: 'cyan',
  },
  {
    id: 'kanby',
    name: 'Kanby',
    tags: ['TypeScript', 'Next.js', 'PostgreSQL', 'Prisma', 'SSE'],
    href: 'https://kanbyldv.vercel.app/',
    accent: 'cyan',
  },
  {
    id: 'macos',
    name: 'MacOS Portfolio',
    tags: ['TypeScript', 'React', 'Zustand', 'GSAP'],
    href: 'https://portfolio-macldv.vercel.app/',
    accent: 'indigo',
  },
];

const projects = baseProjects.map((p) => {
  const content = t.items[p.id];
  return { ...p, ...content };
});
---

<section id="projects" class="relative z-2 px-6 py-28">
  <div class="mx-auto max-w-7xl">
    <div class="reveal mb-14">
      <p class="mb-2 font-mono text-[0.78rem] uppercase tracking-[0.14em] text-accent-secondary">{t.eyebrow}</p>
      <h2 class="text-[clamp(2rem,5vw,3.5rem)] font-bold tracking-[-0.04em] text-fg">{t.heading}</h2>
    </div>

    <div class="grid grid-cols-1 gap-6 md:grid-cols-2">
      {projects.map(({ name, tagline, description, highlights, tags, href, accent }) => (
        <article class={`group relative cursor-pointer overflow-hidden rounded-[20px] border border-border bg-surface-elevated transition-all duration-250 hover:-translate-y-0.5 hover:border-accent-border reveal`}>
          <div class={`pointer-events-none absolute inset-0 opacity-0 transition-opacity duration-300 ${accent === 'cyan' ? '[background:radial-gradient(ellipse_80%_60%_at_50%_0%,var(--accent-glow),transparent)]' : '[background:radial-gradient(ellipse_80%_60%_at_50%_0%,rgba(94_106_210/0.12),transparent)]'} group-hover:opacity-100`}></div>
          <div class="relative z-1 flex h-full flex-col gap-3 p-8">
            <div class="flex items-start justify-between gap-4">
              <h3 class="m-0 text-[1.15rem] font-bold tracking-[-0.02em] text-fg">{name}</h3>
              {href && (
                <a href={href} target="_blank" rel="noopener noreferrer" class="mt-0.5 shrink-0 text-fg-muted transition-colors duration-150 hover:text-accent-secondary" aria-label={`${t.visit} ${name}`}>
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                    <path d="M15 3h6v6M10 14 21 3M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/>
                  </svg>
                </a>
              )}
            </div>
            <p class="m-0 font-mono text-[0.82rem] font-medium text-accent">{tagline}</p>
            <p class="m-0 flex-1 text-[0.9rem] leading-[1.7] text-fg-muted">{description}</p>
            {highlights && highlights.length > 0 && (
              <ul class={`m-0 flex list-none flex-col gap-1.5 border-l-[1.5px] pl-3.5 ${accent === 'cyan' ? 'border-l-cyan-400/30' : 'border-l-indigo-500/40'}`}>
                {highlights.map((item) => (
                  <li class="flex items-baseline gap-2 text-[0.8rem] leading-[1.6] text-fg-muted">
                    <span class={`font-mono text-[0.72rem] ${accent === 'indigo' ? 'text-accent' : 'text-accent-secondary'}`} aria-hidden="true">→</span>
                    <span>{item}</span>
                  </li>
                ))}
              </ul>
            )}
            <div class="mt-2 flex flex-wrap gap-1.5">
              {tags.map((tag) => (
                <span class="rounded-full border border-border bg-surface px-2.5 py-1 text-[0.72rem] text-fg-muted">{tag}</span>
              ))}
            </div>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>
