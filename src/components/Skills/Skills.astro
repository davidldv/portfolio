---
import { SkillsInteractive } from './SkillsInteractive';
---

<section id="skills" class="relative z-2 px-6 py-28">
  <div class="mx-auto max-w-7xl">
    <div class="reveal mb-14">
      <p class="mb-2 font-mono text-[0.78rem] uppercase tracking-[0.14em] text-accent-secondary">Expertise</p>
      <h2 class="text-[clamp(2rem,5vw,3.5rem)] font-bold tracking-[-0.04em] text-fg">Skills</h2>
    </div>

    <SkillsInteractive client:visible />
  </div>
</section>
