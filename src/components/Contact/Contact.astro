---

<section id="contact" class="contact-section">
  <div class="contact-inner">
    <div class="contact-header reveal">
      <p class="contact-eyebrow">Get in touch</p>
      <h2 class="contact-heading">Let's build something</h2>
      <p class="contact-subtext">
        Open to full-time roles, freelance, and interesting side projects.
        If you have a problem worth solving, let's talk.
      </p>
    </div>

    <div class="contact-grid">
      <form class="contact-form reveal" action="/api/contact" method="POST" novalidate>
        <div class="field-row">
          <div class="field">
            <label for="name" class="field-label">Name</label>
            <input id="name" name="name" type="text" class="field-input" placeholder="Your name" required autocomplete="name" />
          </div>
          <div class="field">
            <label for="email" class="field-label">Email</label>
            <input id="email" name="email" type="email" class="field-input" placeholder="you@example.com" required autocomplete="email" />
          </div>
        </div>

        <div class="field">
          <label for="message" class="field-label">Message</label>
          <textarea id="message" name="message" class="field-input field-textarea" placeholder="Tell me about your project or idea..." rows="5" required></textarea>
        </div>

        <button type="submit" class="submit-btn">
          Send message
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M22 2 11 13M22 2 15 22l-4-9-9-4 20-7z"/>
          </svg>
        </button>
      </form>

      <div class="contact-socials reveal">
        <p class="socials-label">Or reach me directly</p>
        <ul class="social-list" role="list">
          {socials.map(({ label, href, icon }) => (
            <li>
              <a
                href={href}
                class="social-row"
                aria-label={label}
                target={href.startsWith('http') ? '_blank' : undefined}
                rel={href.startsWith('http') ? 'noopener noreferrer' : undefined}
              >
                <span class="social-icon">
                  <Fragment set:html={icon} />
                </span>
                <span class="social-name">{label}</span>
                <svg class="social-arrow" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <path d="M5 12h14M12 5l7 7-7 7"/>
                </svg>
              </a>
            </li>
          ))}
        </ul>
      </div>
    </div>
  </div>
</section>

<style>
  .contact-section {
    position: relative;
    z-index: 2;
    padding: 7rem 1.5rem 4rem;
  }

  .contact-inner {
    max-width: 1280px;
    margin: 0 auto;
  }

  .contact-header {
    margin-bottom: 3.5rem;
    max-width: 560px;
  }

  .contact-eyebrow {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.78rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--accent-secondary);
    margin-bottom: 0.5rem;
  }

  .contact-heading {
    font-size: clamp(2rem, 5vw, 3.5rem);
    font-weight: 700;
    letter-spacing: -0.04em;
    color: var(--foreground);
    margin-bottom: 1rem;
  }

  .contact-subtext {
    font-size: 1rem;
    line-height: 1.7;
    color: var(--foreground-muted);
  }

  .contact-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 3rem;
  }

  @media (min-width: 768px) {
    .contact-grid {
      grid-template-columns: 3fr 2fr;
      gap: 5rem;
      align-items: start;
    }
  }

  .contact-form {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  .field-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.25rem;
  }

  @media (max-width: 480px) {
    .field-row { grid-template-columns: 1fr; }
  }

  .field {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }

  .field-label {
    font-size: 0.82rem;
    font-weight: 500;
    color: var(--foreground-muted);
  }

  .field-input {
    background: var(--bg-elevated);
    border: 1px solid var(--border);
    border-radius: 10px;
    padding: 0.75rem 1rem;
    font-size: 0.95rem;
    color: var(--foreground);
    font-family: inherit;
    outline: none;
    transition: border-color 150ms ease;
    width: 100%;
  }

  .field-input::placeholder {
    color: var(--foreground-muted);
    opacity: 0.5;
  }

  .field-input:focus {
    border-color: var(--accent);
  }

  .field-textarea {
    resize: vertical;
    min-height: 130px;
  }

  .submit-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    align-self: flex-start;
    padding: 0.875rem 2rem;
    border-radius: var(--radius);
    background: var(--accent);
    color: #fff;
    font-weight: 600;
    font-size: 0.95rem;
    border: none;
    cursor: pointer;
    box-shadow: 0 0 30px var(--accent-glow);
    transition: opacity 200ms ease, transform 200ms ease;
  }

  .submit-btn:hover {
    opacity: 0.88;
    transform: translateY(-1px);
  }

  .submit-btn:focus-visible {
    outline: 2px solid var(--accent);
    outline-offset: 3px;
  }

  .contact-socials {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .socials-label {
    font-size: 0.82rem;
    font-weight: 500;
    color: var(--foreground-muted);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    font-family: 'JetBrains Mono', monospace;
  }

  .social-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    margin: 0;
    padding: 0;
  }

  .social-row {
    display: flex;
    align-items: center;
    gap: 0.875rem;
    padding: 1rem 1.25rem;
    border-radius: 12px;
    border: 1px solid var(--border);
    background: var(--bg-elevated);
    text-decoration: none;
    color: var(--foreground-muted);
    transition: color 150ms ease, border-color 150ms ease, background 150ms ease;
  }

  .social-row:hover {
    color: var(--foreground);
    border-color: var(--accent-border-mix);
    background: var(--bg-surface);
  }

  .social-icon {
    display: flex;
    align-items: center;
    color: var(--accent);
  }

  .social-name {
    flex: 1;
    font-weight: 500;
    font-size: 0.95rem;
  }

  .social-arrow {
    opacity: 0;
    transform: translateX(-4px);
    transition: opacity 150ms ease, transform 150ms ease;
  }

  .social-row:hover .social-arrow {
    opacity: 1;
    transform: translateX(0);
  }

  .social-row:focus-visible {
    outline: 2px solid var(--accent);
    outline-offset: 2px;
  }
</style>
