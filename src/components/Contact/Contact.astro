---
import { ui, type Lang } from '../../i18n/ui';

interface Props {
  lang?: Lang;
}

const { lang = 'en' } = Astro.props as Props;
const t = ui[lang].contact;

const socials = [
  {
    label: 'GitHub',
    href: 'https://github.com/davidldv',
    icon: `<svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0 1 12 6.844a9.59 9.59 0 0 1 2.504.337c1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.02 10.02 0 0 0 22 12.017C22 6.484 17.522 2 12 2z"/></svg>`,
  },
  {
    label: 'LinkedIn',
    href: 'https://linkedin.com/in/davidldv',
    icon: `<svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>`,
  },
  {
    label: 'X',
    href: 'https://x.com/yuvdxv',
    icon: `<svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>`,
  },
  {
    label: 'Email',
    href: 'mailto:dlondon.dev@gmail.com',
    icon: `<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>`,
  },
  {
    label: 'HackTheBox — @davidldv',
    href: 'https://app.hackthebox.com/users/3395439',
    icon: `<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 2 3 7v10l9 5 9-5V7l-9-5z"/><path d="M3 7l9 5 9-5"/><path d="M12 12v10"/></svg>`,
  },
  {
    label: 'TryHackMe — dlondon.dev',
    href: 'https://tryhackme.com/p/dlondon.dev',
    icon: `<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 2l3 7h7l-5.5 4.5L18 21l-6-4-6 4 1.5-7.5L2 9h7z"/></svg>`,
  },
];
---

<section id="contact" class="relative z-2 px-6 pb-16 pt-28">
  <div class="mx-auto max-w-7xl">
    <div class="reveal mb-14 max-w-140">
      <p class="mb-2 font-mono text-[0.78rem] uppercase tracking-[0.14em] text-accent-secondary">{t.eyebrow}</p>
      <h2 class="mb-4 text-[clamp(2rem,5vw,3.5rem)] font-bold tracking-[-0.04em] text-fg">{t.heading}</h2>
      <p class="text-base leading-[1.7] text-fg-muted">{t.intro}</p>
    </div>

    <div class="grid grid-cols-1 gap-12 md:grid-cols-[3fr_2fr] md:items-start md:gap-20">
      <form
        class="reveal flex flex-col gap-5"
        novalidate
        data-contact-form
        data-label-submit={t.form.submit}
        data-label-sending={t.form.sending}
        data-label-sent={t.form.sent}
        data-label-error={t.form.error}
        data-subject-prefix={t.form.subjectPrefix}
      >
        <input type="hidden" name="access_key" value={import.meta.env.PUBLIC_WEB3FORMS_ACCESS_KEY || 'YOUR_ACCESS_KEY_HERE'} />
        <input type="checkbox" name="botcheck" class="hidden" style="display: none;" />

        <div class="grid grid-cols-1 gap-5 sm:grid-cols-2">
          <div class="flex flex-col gap-1.5">
            <label for="name" class="text-[0.82rem] font-medium text-fg-muted">{t.form.name}</label>
            <input id="name" name="name" type="text" class="w-full rounded-[10px] border border-border bg-surface-elevated px-4 py-3 text-[0.95rem] text-fg outline-none transition-colors duration-150 placeholder:text-fg-muted/50 focus:border-accent" placeholder={t.form.namePlaceholder} required autocomplete="name" />
          </div>
          <div class="flex flex-col gap-1.5">
            <label for="email" class="text-[0.82rem] font-medium text-fg-muted">{t.form.email}</label>
            <input id="email" name="email" type="email" class="w-full rounded-[10px] border border-border bg-surface-elevated px-4 py-3 text-[0.95rem] text-fg outline-none transition-colors duration-150 placeholder:text-fg-muted/50 focus:border-accent" placeholder={t.form.emailPlaceholder} required autocomplete="email" />
          </div>
        </div>

        <div class="flex flex-col gap-1.5">
          <label for="message" class="text-[0.82rem] font-medium text-fg-muted">{t.form.message}</label>
          <textarea id="message" name="message" class="min-h-32.5 w-full resize-y rounded-[10px] border border-border bg-surface-elevated px-4 py-3 text-[0.95rem] text-fg outline-none transition-colors duration-150 placeholder:text-fg-muted/50 focus:border-accent" placeholder={t.form.messagePlaceholder} rows="5" required></textarea>
        </div>

        <button type="submit" class="inline-flex w-fit items-center gap-2 self-start rounded-(--radius) bg-accent px-8 py-3.5 text-[0.95rem] font-semibold text-white shadow-[0_0_30px_var(--accent-glow)] transition-all duration-200 hover:-translate-y-0.5 hover:opacity-90 focus-visible:outline-2 focus-visible:outline-offset-3 focus-visible:outline-accent disabled:cursor-not-allowed disabled:opacity-50 disabled:hover:translate-y-0">
          <span class="btn-text">{t.form.submit}</span>
          <svg class="btn-icon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M22 2 11 13M22 2 15 22l-4-9-9-4 20-7z"/>
          </svg>
        </button>
      </form>

      <div class="reveal flex flex-col gap-6">
        <p class="font-mono text-[0.82rem] font-medium uppercase tracking-[0.08em] text-fg-muted">{t.orReach}</p>
        <ul class="m-0 flex list-none flex-col gap-2 p-0" role="list">
          {socials.map(({ label, href, icon }) => (
            <li>
              <a
                href={href}
                class="group flex items-center gap-3.5 rounded-xl border border-border bg-surface-elevated px-5 py-4 text-fg-muted no-underline transition-colors duration-150 hover:border-accent-border hover:bg-surface hover:text-fg focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-accent"
                aria-label={label}
                target={href.startsWith('http') ? '_blank' : undefined}
                rel={href.startsWith('http') ? 'noopener noreferrer' : undefined}
              >
                <span class="text-accent">
                  <Fragment set:html={icon} />
                </span>
                <span class="flex-1 text-[0.95rem] font-medium">{label}</span>
                <svg class="-translate-x-1 opacity-0 transition-all duration-150 group-hover:translate-x-0 group-hover:opacity-100" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <path d="M5 12h14M12 5l7 7-7 7"/>
                </svg>
              </a>
            </li>
          ))}
        </ul>
      </div>
    </div>
  </div>
</section>

<script>
  const bindContactForm = () => {
    const form = document.querySelector<HTMLFormElement>('[data-contact-form]');
    if (!form || form.dataset.bound === 'true') return;
    form.dataset.bound = 'true';

    const btnText = form.querySelector<HTMLElement>('.btn-text');
    const btnIcon = form.querySelector<SVGSVGElement>('.btn-icon');
    const submitBtn = form.querySelector<HTMLButtonElement>('button[type="submit"]');

    const labels = {
      submit: form.dataset.labelSubmit ?? 'Send message',
      sending: form.dataset.labelSending ?? 'Sending...',
      sent: form.dataset.labelSent ?? 'Message sent!',
      error: form.dataset.labelError ?? 'Error sending',
      subjectPrefix: form.dataset.subjectPrefix ?? '✨ New Portfolio Inquiry from',
    };

    form.addEventListener('submit', async (event) => {
      event.preventDefault();

      if (!form.checkValidity()) {
        form.reportValidity();
        return;
      }

      const formData = new FormData(form);
      const name = String(formData.get('name') ?? '').trim();
      formData.append('subject', `${labels.subjectPrefix} ${name}`);

      const object = Object.fromEntries(formData);
      const json = JSON.stringify(object);

      if (btnText && submitBtn && btnIcon) {
        btnText.textContent = labels.sending;
        submitBtn.disabled = true;
        btnIcon.style.display = 'none';
      }

      try {
        const response = await fetch('https://api.web3forms.com/submit', {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json',
            Accept: 'application/json',
          },
          body: json,
        });

        const data = await response.json();

        if (data.success) {
          form.reset();
          if (btnText) btnText.textContent = labels.sent;

          setTimeout(() => {
            if (btnText && submitBtn && btnIcon) {
              btnText.textContent = labels.submit;
              submitBtn.disabled = false;
              btnIcon.style.display = 'block';
            }
          }, 3000);
        } else {
          throw new Error(data.message || 'Something went wrong');
        }
      } catch (error) {
        console.error(error);
        if (btnText && submitBtn && btnIcon) {
          btnText.textContent = labels.error;
          btnIcon.style.display = 'block';
          submitBtn.disabled = false;
        }
      }
    });
  };

  document.addEventListener('astro:page-load', bindContactForm);
  bindContactForm();
</script>
